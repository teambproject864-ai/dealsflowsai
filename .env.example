# AI Provider Selection: "huggingface" or "nvidia"
AI_PROVIDER=huggingface

# Hugging Face Inference API — https://huggingface.co/settings/tokens (read token is enough)
HUGGINGFACE_API_TOKEN=

# Nvidia API Key — https://build.nvidia.com/
NVIDIA_API_KEY=

# Optional aliases: HF_TOKEN or HUGGING_FACE_HUB_TOKEN
# Optional: pin one model id (otherwise the app tries a short fallback list)
# HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.3
# Optional: force a provider from your HF inference settings (omit or "auto" for router)
# https://huggingface.co/settings/inference-providers
# HUGGINGFACE_INFERENCE_PROVIDER=together
# Optional caps (defaults: analysis 4096, chat 4096) — lower if a provider rejects large max_tokens
# HUGGINGFACE_MAX_TOKENS_ANALYSIS=4096
# HUGGINGFACE_MAX_TOKENS_CHAT=4096

# Firebase Admin SDK (NOT firebase.json CLI hosting config — use your *-adminsdk-*.json key file)
# Priority: FIREBASE_SERVICE_ACCOUNT_PATH → GOOGLE_APPLICATION_CREDENTIALS → dealflow_firebase.json in project root
FIREBASE_SERVICE_ACCOUNT_PATH=./dealflow_firebase.json
# FIREBASE_SERVICE_ACCOUNT_PATH=./dealflow-ai-651cb-firebase-adminsdk-fbsvc-130a39ea58.json
#
# Optional if not using JSON file:
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Cal.com path only, e.g. praneeth-burada-smbryh/30min
NEXT_PUBLIC_CAL_LINK=praneeth-burada-smbryh/30min

NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/praneethburada/30min

# Recall.ai region for Meeting Bot API (example: us-east-1, us-west-2)
RECALL_REGION=us-east-1

# Twilio — outbound meeting confirmation calls (post-booking)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Google Calendar & Meet
# Optional: GOOGLE_CALENDAR_ID — if not set, defaults to "primary"
# To get a calendar ID: Go to Google Calendar → Settings → Select calendar → Integrate calendar → Calendar ID
GOOGLE_CALENDAR_ID=

# Optional: GOOGLE_CALENDAR_TIMEZONE — defaults to UTC
# Example: "America/New_York", "Europe/London"
GOOGLE_CALENDAR_TIMEZONE=UTC
