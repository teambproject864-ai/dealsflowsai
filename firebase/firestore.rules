rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is accessing their own data
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Leads are written only from Next.js API routes via the Admin SDK.
    // Lock down client access; adjust if you add a client-side Firebase app.
    match /leads/{leadId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only via Admin SDK
    }

    // ALMA Memories
    match /alma_memory/{memoryId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only via Admin SDK
    }

    // Features are public read-only
    match /features/{featureId} {
      allow read: if true;
      allow write: if false; // Only via Admin SDK/API
    }

    // User profiles
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
