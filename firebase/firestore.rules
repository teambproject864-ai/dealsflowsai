rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Leads are public read-only for now as auth is removed.
    // In production, you would use API keys or other server-side checks.
    match /leads/{leadId} {
      allow read: if true;
      allow write: if false; // Only via Admin SDK
    }

    // ALMA Memories
    match /alma_memory/{memoryId} {
      allow read: if true;
      allow write: if false; // Only via Admin SDK
    }

    // Features are public read-only
    match /features/{featureId} {
      allow read: if true;
      allow write: if false; // Only via Admin SDK/API
    }

    // User profiles - Removed as auth is removed
    match /users/{userId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
